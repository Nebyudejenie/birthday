# ─────────────────────────────────────────────────────────────
#  Ebony's Birthday — deployment environment
#  Copy to .env (setup.sh does this for you) and fill in the blanks.
#  NEVER commit .env — it is git-ignored.
# ─────────────────────────────────────────────────────────────

# Public production domain (DNS + HTTPS handled by Cloudflare)
DOMAIN=ebony-mylove.online

NODE_ENV=production

# Internal app port — NOT published to the host; the tunnel fronts it.
PORT=3000

# Server timezone (affects the live "Addis Ababa / Cleveland" clocks server-side)
TZ=Africa/Addis_Ababa

# Docker image naming
IMAGE_NAME=ebony-birthday
TAG=latest

# ── Cloudflare Tunnel (locally-managed) ──
# Create with:  cloudflared tunnel create ebony
# Then copy the printed Tunnel ID here and place its credentials JSON in
# ./cloudflared/  (see cloudflared/README.md).
CLOUDFLARE_TUNNEL_ID=REPLACE_WITH_TUNNEL_ID
CLOUDFLARE_CREDENTIALS_PATH=./cloudflared/REPLACE_WITH_TUNNEL_ID.json
